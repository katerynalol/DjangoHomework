      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedTaskList'
          description: ''
  /task/stat/:
    get:
      operationId: task_stat_retrieve
      tags:
      - task
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
components:
  schemas:
    CategoryCount:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          title: Название категории
          maxLength: 50
        task_count:
          type: integer
          readOnly: true
        is_deleted:
          type: boolean
      required:
      - id
      - name
      - task_count
    CategoryCreate:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          title: Название категории
          maxLength: 50
        is_deleted:
          type: boolean
        deleted_at:
          type: string
          format: date-time
          nullable: true
          title: Дата и время удаления
      required:
      - id
      - name
    CategoryCreateRequest:
      type: object
      properties:
        name:
          type: string
          minLength: 1
          title: Название категории
          maxLength: 50
        is_deleted:
          type: boolean
        deleted_at:
          type: string
          format: date-time
          nullable: true
          title: Дата и время удаления
      required:
      - name
    PaginatedCategoryCountList:
      type: object
      required:
      - results
      properties:
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?cursor=cD00ODY%3D"
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?cursor=cj0xJnA9NDg3
        results:
          type: array
          items:
            $ref: '#/components/schemas/CategoryCount'
    PaginatedSubTaskList:
      type: object
      required:
      - results
      properties:
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?cursor=cD00ODY%3D"
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?cursor=cj0xJnA9NDg3
        results:
          type: array
          items:
            $ref: '#/components/schemas/SubTask'
    PaginatedTaskList:
      type: object
      required:
      - results
      properties:
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?cursor=cD00ODY%3D"
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?cursor=cj0xJnA9NDg3
        results:
          type: array
          items:
            $ref: '#/components/schemas/Task'
    PatchedCategoryCreateRequest:
      type: object
      properties:
        name:
          type: string
          minLength: 1
          title: Название категории
          maxLength: 50
        is_deleted:
          type: boolean
        deleted_at:
          type: string
          format: date-time
          nullable: true
          title: Дата и время удаления
    PatchedSubTaskRequest:
      type: object
      properties:
        title:
          type: string
          minLength: 1
          title: Название подзадачи
          maxLength: 100
        description:
          type: string
          minLength: 5
          title: Описание подзадачи
          maxLength: 500
        status:
          allOf:
          - $ref: '#/components/schemas/StatusEnum'
          title: Статус подзадачи
        owner:
          type: integer
          title: Владелец подзадачи
    PatchedTaskCreateRequest:
      type: object
      properties:
        title:
          type: string
          minLength: 1
          title: Название задачи
          maxLength: 100
        description:
          type: string
          minLength: 5
          title: Описание задачи
          maxLength: 500
        status:
          allOf:
          - $ref: '#/components/schemas/StatusEnum'
          title: Статус задачи
        deadline:
          type: string
          format: date-time
          title: Дата и время дедлайна
    StatusEnum:
      enum:
      - New
      - In progress
      - Pending
      - Blocked
      - Done
      type: string
      description: |-
        * `New` - New task
        * `In progress` - Active task
        * `Pending` - Pending...
        * `Blocked` - Blocked
        * `Done` - Finished
    SubTask:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        title:
          type: string
          title: Название подзадачи
          maxLength: 100
        description:
          type: string
          title: Описание подзадачи
          minLength: 5
          maxLength: 500
        status:
          allOf:
          - $ref: '#/components/schemas/StatusEnum'
          title: Статус подзадачи
        owner:
          type: integer
          title: Владелец подзадачи
      required:
      - description
      - id
      - owner
      - title
    SubTaskRequest:
      type: object
      properties:
        title:
          type: string
          minLength: 1
          title: Название подзадачи
          maxLength: 100
        description:
          type: string
          minLength: 5
          title: Описание подзадачи
          maxLength: 500
        status:
          allOf:
          - $ref: '#/components/schemas/StatusEnum'
          title: Статус подзадачи
        owner:
          type: integer
          title: Владелец подзадачи
      required:
      - description
      - owner
      - title
    Task:
      type: object
      properties:
        title:
          type: string
          title: Название задачи
          maxLength: 100
        description:
          type: string
          title: Описание задачи
          minLength: 5
          maxLength: 500
        status:
          allOf:
          - $ref: '#/components/schemas/StatusEnum'
          title: Статус задачи
        deadline:
          type: string
          format: date-time
          title: Дата и время дедлайна
        created_at:
          type: string
          format: date-time
          readOnly: true
          title: Дата и время создания
        owner:
          type: integer
          title: Владелец задачи
      required:
      - created_at
      - deadline
      - description
      - owner
      - title
    TaskCreate:
      type: object
      properties:
        title:
          type: string
          title: Название задачи
          maxLength: 100
        description:
          type: string
          title: Описание задачи
          minLength: 5
          maxLength: 500
        status:
          allOf:
          - $ref: '#/components/schemas/StatusEnum'
          title: Статус задачи
        deadline:
          type: string
          format: date-time
          title: Дата и время дедлайна
      required:
      - deadline
      - description
      - title
    TaskCreateRequest:
      type: object
      properties:
        title:
          type: string
          minLength: 1
          title: Название задачи
          maxLength: 100
        description:
          type: string
          minLength: 5
          title: Описание задачи
          maxLength: 500
        status:
          allOf:
          - $ref: '#/components/schemas/StatusEnum'
          title: Статус задачи
        deadline:
          type: string
          format: date-time
          title: Дата и время дедлайна
      required:
      - deadline
      - description
      - title
    TaskRequest:
      type: object
      properties:
        title:
          type: string
          minLength: 1
          title: Название задачи
          maxLength: 100
        description:
          type: string
          minLength: 5
          title: Описание задачи
          maxLength: 500
        status:
          allOf:
          - $ref: '#/components/schemas/StatusEnum'
          title: Статус задачи
        deadline:
          type: string
          format: date-time
          title: Дата и время дедлайна
        owner:
          type: integer
          title: Владелец задачи
      required:
      - deadline
      - description
      - owner
      - title
    TokenObtainPair:
      type: object
      properties:
        access:
          type: string
          readOnly: true
        refresh:
          type: string
          readOnly: true
      required:
      - access
      - refresh
    TokenObtainPairRequest:
      type: object
      properties:
        username:
          type: string
          writeOnly: true
          minLength: 1
        password:
          type: string
          writeOnly: true
          minLength: 1
      required:
      - password
      - username
    TokenRefresh:
      type: object
      properties:
        access:
          type: string
          readOnly: true
      required:
      - access
    TokenRefreshRequest:
      type: object
      properties:
        refresh:
          type: string
          writeOnly: true
          minLength: 1
      required:
      - refresh
  securitySchemes:
    jwtAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
